  "components": {
    "schemas": {
      "InternalPersonalWorkspaceResponse": {
        "type": "object",
        "description": "Get-or-create result for a user's personal workspace (service-to-service).",
        "properties": {
          "workspace_id": {
            "type": "string",
            "format": "uuid",
            "description": "Personal workspace UUID."
          }
        },
        "required": [
          "workspace_id"
        ]
      },
      "InvitationAcceptRequest": {
        "type": "object",
        "description": "Accept an invite.",
        "properties": {
          "token": {
            "type": "string",
            "description": "Invite token from the email link"
          }
        },
        "required": [
          "token"
        ]
      },
      "InvitationResponse": {
        "type": "object",
        "description": "InvitationResponse(id: uuid.UUID, workspace_id: uuid.UUID, email: str, role: str, expires_at: str, accepted_at: Optional[str], revoked_at: Optional[str], created_at: str)",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "workspace_id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "expires_at": {
            "type": "string"
          },
          "accepted_at": {
            "type": "string",
            "nullable": true
          },
          "revoked_at": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string"
          }
        },
        "required": [
          "accepted_at",
          "created_at",
          "email",
          "expires_at",
          "id",
          "revoked_at",
          "role",
          "workspace_id"
        ]
      },
      "MemberInviteRequest": {
        "type": "object",
        "description": "Invite payload.",
        "properties": {
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "One or more emails to invite",
            "example": [
              "alice@example.com"
            ]
          },
          "role": {
            "type": "string",
            "description": "Role to grant on acceptance",
            "example": "member"
          }
        },
        "required": [
          "emails"
        ]
      },
      "MemberInviteResponse": {
        "type": "object",
        "description": "MemberInviteResponse(invitations: List[ForwardRef('InvitationResponse')] = <factory>)",
        "properties": {
          "invitations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvitationResponse"
            }
          }
        }
      },
      "MemberListResponse": {
        "type": "object",
        "description": "MemberListResponse(members: List[stapel_workspaces.dto.MemberResponse] = <factory>)",
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemberResponse"
            }
          }
        }
      },
      "MemberResponse": {
        "type": "object",
        "description": "Workspace member.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Membership UUID",
            "example": "0192..."
          },
          "workspace_id": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace UUID"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "description": "User UUID"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "description": "User email (best-effort, from JWT claim cache)"
          },
          "role": {
            "type": "string",
            "description": "owner / admin / member / viewer",
            "example": "admin"
          },
          "invited_at": {
            "type": "string",
            "description": "ISO 8601 invite timestamp"
          },
          "accepted_at": {
            "type": "string",
            "nullable": true,
            "description": "ISO 8601 acceptance timestamp; null while pending"
          },
          "last_accessed_at": {
            "type": "string",
            "nullable": true,
            "description": "ISO 8601 last access; null if never accessed"
          }
        },
        "required": [
          "accepted_at",
          "email",
          "id",
          "invited_at",
          "last_accessed_at",
          "role",
          "user_id",
          "workspace_id"
        ]
      },
      "PatchedMemberUpdateRequest": {
        "type": "object",
        "description": "MemberUpdateRequest(role: str)",
        "properties": {
          "role": {
            "type": "string"
          }
        }
      },
