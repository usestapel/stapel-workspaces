            "type": "string",
            "description": "Display name",
            "example": "Acme Engineering"
          },
          "slug": {
            "type": "string",
            "description": "URL-safe identifier",
            "example": "acme-eng"
          },
          "type": {
            "type": "string",
            "description": "Workspace category",
            "example": "work"
