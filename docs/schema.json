          "name": {
            "type": "string",
            "nullable": true
          },
          "slug": {
            "type": "string",
            "nullable": true
          },
          "settings": {
            "type": "object",
            "additionalProperties": {},
            "nullable": true
          }
        }
      },
      "StapelError": {
        "type": "object",
        "description": "Structured error returned by all Stapel API endpoints.",
        "properties": {
          "localizable_error": {
            "type": "string",
            "description": "Translation key for client-side localization",
            "example": "error.404.not_found"
          },
          "error": {
            "type": "string",
            "description": "Human-readable message in English",
            "example": "Requested resource not found"
          },
          "params": {
            "type": "object",
            "additionalProperties": {},
            "description": "Context values for template placeholders",
            "example": {
              "retry_after": 30
            }
          }
        },
        "required": [
          "error",
          "localizable_error"
        ]
      },
      "WorkspaceCreateRequest": {
        "type": "object",
        "description": "Create-workspace payload.",
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name",
            "example": "Acme Engineering"
          },
          "slug": {
            "type": "string",
            "nullable": true,
            "description": "URL-safe identifier (auto-generated when omitted)",
            "example": "acme-eng"
          },
          "type": {
            "type": "string",
            "description": "personal or work",
            "example": "work"
          }
        },
        "required": [
          "name"
        ]
      },
      "WorkspaceListResponse": {
        "type": "object",
        "description": "WorkspaceListResponse(workspaces: List[stapel_workspaces.dto.WorkspaceResponse] = <factory>)",
        "properties": {
          "workspaces": {
            "type": "array",
            "items": {
